{
  "name": "@jamesdowzard/godot-mcp",
  "version": "0.2.0",
  "description": "MCP server for Godot 4 with Android export validator support. Fork of Coding-Solo/godot-mcp.",
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "cline",
    "android-export",
    "vr"
  ],
  "homepage": "https://github.com/jamesdowzard/godot-mcp",
  "bugs": {
    "url": "https://github.com/jamesdowzard/godot-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesdowzard/godot-mcp.git"
  },
  "license": "MIT",
  "author": "James Dowzard <james.dowzard@gmail.com>",
  "contributors": [
    "Solomon Elias <solomon@sippy.ai> (original author)"
  ],
  "type": "module",
  "bin": {
    "godot-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "axios": "^1.7.9",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
